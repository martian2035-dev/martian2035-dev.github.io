---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" class="mx-auto w-full max-w-3xl pb-4">
    <section id="hero" class="pt-8 pb-6">
      <h1 class="my-4 text-3xl font-bold sm:my-8 sm:text-4xl">
        {SITE.title}
      </h1>
      <p class="mt-2 mb-6 italic text-foreground/70">
        {SITE.desc}
      </p>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-6 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="mb-2 text-lg font-semibold tracking-wide">推荐文章</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-6 pb-6">
          <h2 class="mb-2 text-lg font-semibold tracking-wide">最新文章</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-6 text-center">
      <a
        href="/posts/"
        class="inline-block text-sm text-accent hover:underline"
      >
        所有文章 →
      </a>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    sessionStorage.setItem("backUrl", "/");
  });
</script>
